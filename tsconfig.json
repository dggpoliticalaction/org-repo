{
  "extends": "./tsconfig.nextjs.json",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,

    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@payload-config": ["./src/payload.config.ts"],
      "react": ["./node_modules/@types/react"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "redirects.js",
    "next.config.js",
    "next-sitemap.config.cjs",
    "scripts/install-fonts.cjs"
  ],
  "exclude": ["node_modules"]
}
