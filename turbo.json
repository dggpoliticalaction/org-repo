{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "NODE_ENV",
        "S3_ENDPOINT",
        "S3_REGION",
        "S3_BUCKET",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "VERCEL_PROJECT_PRODUCTION_URL",
        "PREVIEW_SECRET",
        "DATABASE_URI",
        "PAYLOAD_SECRET",
        "CRON_SECRET",
        "NEXT_PUBLIC_GOOGLE_ANALYTICS_ID",
        "NEXT_PUBLIC_SERVER_URL",
        "NEXT_PUBLIC_SUPABASE_URL"
      ]
    },
    "lint:fix":{
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "format:fix": {
      "dependsOn": ["^format:fix"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev:install": {
      "cache": false
    },
    "dev:db": {
      "cache": false
    },
    "dev:next": {
      "dependsOn": ["^dev:install", "^dev:db"],
      "cache": false,
      "persistent": true
    },
    "dev:db-down": {
      "cache": false
    },
    "dev:db-nuke": {
      "cache": false
    },
    "dev:reseed": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "ci": {
      "dependsOn": ["^ci"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "NODE_ENV",
        "S3_ENDPOINT",
        "S3_REGION",
        "S3_BUCKET",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "VERCEL_PROJECT_PRODUCTION_URL",
        "PREVIEW_SECRET",
        "USE_LOCAL_STORAGE",
        "DATABASE_ADAPTER",
        "DATABASE_URI",
        "PAYLOAD_SECRET",
        "CRON_SECRET",
        "NEXT_PUBLIC_GOOGLE_ANALYTICS_ID",
        "NEXT_PUBLIC_SERVER_URL",
        "NEXT_PUBLIC_SUPABASE_URL"
      ]
    }
  }
}
