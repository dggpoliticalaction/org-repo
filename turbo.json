{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint-staged": {},
    "lint:fix": {},
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "format:fix": {
      "dependsOn": ["^format:fix"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev:db": {
      "cache": false
    },
    "dev:next": {
      "dependsOn": ["^dev:db"],
      "cache": false,
      "persistent": true
    },
    "dev:db-down": {
      "cache": false
    },
    "dev:db-nuke": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
