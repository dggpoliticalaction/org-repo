{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev:install": "turbo run dev:install",
    "dev:db-nuke": "turbo run dev:db-nuke",
    "dev:db-init": "turbo run dev:db",
    "dev:db-logs": "turbo run dev:db-logs",
    "dev:db-down": "turbo run dev:db-down",
    "dev": "turbo run dev:install dev:db-init dev:db-logs dev:next",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint -- --max-warnings 0",
    "lint:fix": "turbo run lint -- --fix",
    "format": "turbo run format",
    "format:fix": "turbo run format:fix",
    "check-types": "turbo run check-types",
    "prepare": "husky",
    "ci": "turbo run ci"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "turbo": "^2.6.2",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "core-js-pure",
      "esbuild",
      "sharp"
    ]
  }
}
