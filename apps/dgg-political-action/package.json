{
  "name": "dgg-political-action",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev:install": "cross-env NODE_OPTIONS=--no-deprecation pnpm install",
    "dev:clear-db": "docker volume ls -q | grep -q '^dgg_political_action_postgres_data$' && docker volume rm dgg_political_action_postgres_data",
    "dev:db": "docker compose -p dgg-political-action -f docker-compose.dev.yml up -d",
    "dev:db-down": "docker compose -p dgg-political-action -f docker-compose.dev.yml down",
    "dev:next": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "dev": "turbo run dev:install dev:db dev:next",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint --fix .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "check-types": "cross-env NODE_OPTIONS=--no-deprecation tsc --noEmit"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "^3.70.0",
    "@payloadcms/db-postgres": "^3.70.0",
    "@payloadcms/live-preview-react": "^3.70.0",
    "@payloadcms/next": "^3.70.0",
    "@payloadcms/payload-cloud": "^3.70.0",
    "@payloadcms/plugin-form-builder": "^3.70.0",
    "@payloadcms/plugin-nested-docs": "^3.70.0",
    "@payloadcms/plugin-redirects": "^3.70.0",
    "@payloadcms/plugin-search": "^3.70.0",
    "@payloadcms/plugin-seo": "^3.70.0",
    "@payloadcms/richtext-lexical": "^3.70.0",
    "@payloadcms/ui": "^3.70.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "geist": "^1.5.1",
    "graphql": "^16.12.0",
    "lucide-react": "^0.378.0",
    "next": "^15.5.9",
    "next-sitemap": "^4.2.3",
    "payload": "^3.70.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.71.0",
    "sharp": "^0.32.6",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/typography": "^0.5.19",
    "@types/escape-html": "^1.0.4",
    "@types/node": "22.5.4",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.2",
    "autoprefixer": "^10.4.23",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "^15.5.9",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.19",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=22",
    "pnpm": "^10"
  }
}
