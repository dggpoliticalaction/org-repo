{
  "name": "pragmatic-papers",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev:install": "cross-env NODE_OPTIONS=--no-deprecation pnpm install",
    "dev:db-nuke": "docker compose -p pragmatic-papers -f docker-compose.yml down && docker volume rm pragmatic_papers_postgres_data",
    "dev:db": "docker compose -p pragmatic-papers -f docker-compose.yml up",
    "dev:db-down": "docker compose -p pragmatic-papers -f docker-compose.yml down",
    "dev:next": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 8000",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "dev": "turbo run dev:install dev:db dev:next",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint --fix .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation PAYLOAD_CONFIG_PATH=src/payload.config.ts payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "check-types": "cross-env NODE_OPTIONS=--no-deprecation tsc --noEmit",
    "ci": "payload migrate && pnpm build",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create",
    "migrate:status": "payload migrate:status",
    "recommendations:update": "tsx --env-file=.env scripts/updateRecommendations.ts"
  },
  "dependencies": {
    "@designbycode/tailwindcss-text-stroke": "^1.3.0",
    "@google-analytics/data": "^5.2.1",
    "@next/third-parties": "^15.3.6",
    "@payloadcms/admin-bar": "^3.70.0",
    "@payloadcms/db-postgres": "^3.70.0",
    "@payloadcms/live-preview-react": "^3.70.0",
    "@payloadcms/next": "^3.70.0",
    "@payloadcms/plugin-form-builder": "^3.70.0",
    "@payloadcms/plugin-nested-docs": "^3.70.0",
    "@payloadcms/plugin-redirects": "^3.70.0",
    "@payloadcms/plugin-search": "^3.70.0",
    "@payloadcms/plugin-seo": "^3.70.0",
    "@payloadcms/richtext-lexical": "^3.70.0",
    "@payloadcms/storage-s3": "^3.70.0",
    "@payloadcms/ui": "^3.70.0",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "better-react-mathjax": "^2.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "feed": "^5.1.0",
    "geist": "^1.4.2",
    "graphql": "^16.12.0",
    "lucide-react": "^0.378.0",
    "next": "^15.5.9",
    "next-sitemap": "^4.2.3",
    "node-cache": "^5.1.2",
    "payload": "^3.70.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.60.0",
    "sanitize-html": "^2.13.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/typography": "^0.5.16",
    "@types/escape-html": "^1.0.4",
    "@types/node": "^22.16.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/sanitize-html": "^2.16.0",
    "autoprefixer": "^10.4.22",
    "copyfiles": "^2.4.1",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.5.9",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22",
    "pnpm": "^10"
  }
}
