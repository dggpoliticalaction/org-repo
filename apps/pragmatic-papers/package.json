{
  "name": "pragmatic-papers",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbo",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint --fix .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "check-types": "cross-env NODE_OPTIONS=--no-deprecation tsc --noEmit",
    "ci": "NODE_ENV=production payload migrate && pnpm build",
    "migrate": "NODE_ENV=production payload migrate",
    "migrate:create": "NODE_ENV=production payload migrate:create",
    "migrate:status": "NODE_ENV=production payload migrate:status",
    "payload:schema": "payload generate:db-schema",
    "drizzle:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@daveyplate/better-auth-ui": "^3.3.15",
    "@designbycode/tailwindcss-text-stroke": "^1.3.0",
    "@libsql/client": "^0.17.0",
    "@next/third-parties": "^15.3.6",
    "@payloadcms/admin-bar": "^3.70.0",
    "@payloadcms/db-postgres": "^3.70.0",
    "@payloadcms/db-sqlite": "^3.70.0",
    "@payloadcms/live-preview-react": "^3.70.0",
    "@payloadcms/next": "^3.70.0",
    "@payloadcms/plugin-form-builder": "^3.70.0",
    "@payloadcms/plugin-nested-docs": "^3.70.0",
    "@payloadcms/plugin-redirects": "^3.70.0",
    "@payloadcms/plugin-search": "^3.70.0",
    "@payloadcms/plugin-seo": "^3.70.0",
    "@payloadcms/richtext-lexical": "^3.70.0",
    "@payloadcms/storage-s3": "^3.70.0",
    "@payloadcms/ui": "^3.70.0",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "better-auth": "^1.4.12",
    "better-react-mathjax": "^2.3.0",
    "better-sqlite3": "^12.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.0",
    "drizzle-orm": "^0.45.1",
    "feed": "^5.1.0",
    "geist": "^1.4.2",
    "graphql": "^16.12.0",
    "lucide-react": "^0.378.0",
    "next": "^15.5.9",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "node-cache": "^5.1.2",
    "payload": "^3.70.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.60.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.16",
    "@types/better-sqlite3": "^7.6.13",
    "@types/escape-html": "^1.0.4",
    "@types/node": "^22.16.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "copyfiles": "^2.4.1",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.5.9",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22",
    "pnpm": "^10"
  }
}
