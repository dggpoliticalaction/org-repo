# Docker Compose Environment Variables
# Copy this file to .env and fill in your values
# For use with Coolify, set these environment variables in the Coolify UI

# ======================
# PostgreSQL Configuration
# ======================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=main_db
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_MAX_CONNECTIONS=200

# ======================
# General Configuration
# ======================
# BUILD_ENV controls deployment behavior
# - preview: Automatically appends COOLIFY_FQDN prefix to database names
# - staging: Uses DATABASE_URI as-is
# - production: Uses DATABASE_URI as-is
BUILD_ENV=staging  # or preview, production

# Coolify-specific (automatically set by Coolify for preview deployments)
# Example: "pr-330.pragmaticpapers.com"
# The prefix (e.g., "pr-330") will be automatically appended to database names
# ONLY when BUILD_ENV=preview
# Leave empty or unset for staging/production deployments
COOLIFY_FQDN=

# ======================
# Build Configuration (Coolify build args)
# ======================
# GitHub Packages auth for @digitalgroundgame (e.g. fonts). PAT with read:packages scope.
# Pass as build arg when building images that need org packages.
GH_FONT_READ=YOUR_GITHUB_TOKEN_HERE

# ======================
# Pragmatic Papers Configuration
# ======================
# PostgreSQL Database Configuration (required)
# Format: postgresql://user:password@host:port/database
# Note: If BUILD_ENV=preview and COOLIFY_FQDN is set (e.g., "pr-330.pragmaticpapers.com"), 
# the database name will automatically become "pragmatic_papers_pr_330"
DATABASE_URI=postgresql://postgres:your_secure_password_here@postgres:5432/pragmatic_papers

# Database Copy Configuration for Preview Deployments
# Enable this to create an isolated database copy for preview deployments
# This prevents schema mismatches between staging and preview environments
COPY_SOURCE_DATABASE=false

# Source database to copy from (typically your staging database)
# Example: postgresql://postgres:password@staging-db-host:5432/pragmatic_papers_staging
SOURCE_DATABASE_URI=

# Force database copy even if target database already exists
# WARNING: This will DROP the existing target database and recreate it
# Use with caution - typically only needed for rebuild scenarios
FORCE_DATABASE_COPY=false

# Payload CMS Secret (generate with: openssl rand -base64 32)
PAYLOAD_SECRET=your_secret_key_here

# Storage Configuration
# Set to 'true' to use local file storage (recommended for staging/preview)
# Set to 'false' to use S3 storage (recommended for production)
USE_LOCAL_STORAGE=true

# S3 Storage Configuration (only needed when USE_LOCAL_STORAGE=false)
S3_REGION=us-east-1
S3_BUCKET=pragmatic-papers-staging
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_ENDPOINT=https://s3.amazonaws.com  # or your S3-compatible endpoint

# ======================
# DGG Political Action Configuration
# ======================
# PostgreSQL Database Configuration (required)
# Format: postgresql://user:password@host:port/database
# Note: If BUILD_ENV=preview and COOLIFY_FQDN is set (e.g., "pr-330.dggpoliticalaction.com"), 
# the database name will automatically become "dgg_political_action_pr_330"
DATABASE_URI=postgresql://postgres:your_secure_password_here@postgres:5432/dgg_political_action

# Payload CMS Secret (generate with: openssl rand -base64 32)
PAYLOAD_SECRET=your_secret_key_here

# Public URLs
NEXT_PUBLIC_SERVER_URL=https://your-dgg-staging-domain.com
