# Docker Compose Environment Variables
# Copy this file to .env and fill in your values
# For use with Coolify, set these environment variables in the Coolify UI

# ======================
# PostgreSQL Configuration
# ======================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=main_db
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_MAX_CONNECTIONS=200

# ======================
# General Configuration
# ======================
BUILD_ENV=staging  # or preview, production

# ======================
# Pragmatic Papers Configuration
# ======================
# Database - Format: postgresql://user:password@host:port/database
PRAGMATIC_PAPERS_DATABASE_URI=postgresql://postgres:your_secure_password_here@postgres:5432/pragmatic_papers

# Payload CMS Secret (generate with: openssl rand -base64 32)
PRAGMATIC_PAPERS_PAYLOAD_SECRET=your_secret_key_here

# Storage Configuration
# Set to 'true' to use local file storage (recommended for staging/preview)
# Set to 'false' or leave unset to use S3 storage (recommended for production)
USE_LOCAL_STORAGE=true

# S3 Storage Configuration (only needed when USE_LOCAL_STORAGE=false)
S3_REGION=us-east-1
S3_BUCKET=pragmatic-papers-staging
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_ENDPOINT=https://s3.amazonaws.com  # or your S3-compatible endpoint

# Public URLs
PRAGMATIC_PAPERS_NEXT_PUBLIC_SERVER_URL=https://your-staging-domain.com
PRAGMATIC_PAPERS_NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_if_needed

# ======================
# DGG Political Action Configuration
# ======================
# Database - Format: postgresql://user:password@host:port/database
DGG_DATABASE_URI=postgresql://postgres:your_secure_password_here@postgres:5432/dgg_political_action

# Payload CMS Secret (generate with: openssl rand -base64 32)
DGG_PAYLOAD_SECRET=your_secret_key_here

# Public URLs
DGG_NEXT_PUBLIC_SERVER_URL=https://your-dgg-staging-domain.com

# ======================
# Discord Bot Configuration
# ======================
# Discord Bot Credentials
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_GUILD_ID=your_discord_guild_id

# Database (if needed)
DISCORD_BOT_DATABASE_URL=postgresql://postgres:your_secure_password_here@postgres:5432/discord_bot
