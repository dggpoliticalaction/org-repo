#!/bin/sh

# 1. Ensure we are in the project root
cd "$(git rev-parse --show-toplevel)"

echo "🚀 Running Turbo Lint..."

# 2. Execute your lint command
# We use 'npm run' so it finds the local version of turbo in node_modules
npm run lint:ci

# 3. Capture the exit code
status=$?

if [ $status -ne 0 ]; then
    echo "❌ Linting failed. Commit aborted."
    exit $status
fi

echo "✅ Linting passed!"
exit 0